# syntax=docker/dockerfile:1
#
# Installs the freshly built RStudio Server RPM on a clean Rocky Linux 10
# image, alongside R, and runs a smoke test.

FROM rockylinux/rockylinux:10

# Repos: CRB + EPEL provide R and assorted runtime libraries.
#
# NOTE: Rocky containers ship `tsflags=nodocs` in /etc/dnf/dnf.conf, which
# strips %doc files. R's doc dir (/usr/share/doc/R) is a %doc directory, and
# rserver refuses to start if it is missing ("R doc dir not found"). Install R
# with docs enabled (tsflags='') so that directory exists.
RUN set -eux; \
    dnf -y install dnf-plugins-core; \
    dnf config-manager --set-enabled crb || dnf config-manager --enable crb; \
    dnf -y install epel-release; \
    dnf -y --setopt=tsflags='' install R-core; \
    dnf -y install procps-ng curl shadow-utils; \
    dnf clean all

# The RPM is copied into the image build context by the Makefile.
COPY output/*.rpm /tmp/
COPY scripts/test-rpm.sh /usr/local/bin/test-rpm.sh
RUN chmod +x /usr/local/bin/test-rpm.sh

# Install the RPM (and resolve any runtime deps).
RUN set -eux; dnf -y install /tmp/rstudio-server-*.rpm

EXPOSE 8787
CMD ["/usr/local/bin/test-rpm.sh"]
